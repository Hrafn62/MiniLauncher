<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paramètres MonLauncher"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Définir comme Launcher par défaut"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de favoris (1-8)"
            android:textColor="#BBBBBB" />

        <EditText
            android:id="@+id/edit_fav_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:hint="Ex: 5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alignement du texte"
            android:textColor="#BBBBBB"
            android:layout_marginTop="20dp" />

        <Spinner
            android:id="@+id/spinner_alignment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Geste : Balayer à Gauche"
            android:textColor="#BBBBBB"
            android:layout_marginTop="20dp" />

        <Spinner
            android:id="@+id/spinner_swipe_left"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Geste : Balayer à Droite"
            android:textColor="#BBBBBB"
            android:layout_marginTop="20dp" />

        <Spinner
            android:id="@+id/spinner_swipe_right"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enregistrer"
            android:layout_marginTop="40dp"
            android:backgroundTint="#333333" />

    </LinearLayout>
</ScrollView>